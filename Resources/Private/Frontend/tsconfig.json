{
	"compilerOptions": {
		"target": "es2020",
		"allowSyntheticDefaultImports": true,
		"incremental": true,
		"tsBuildInfoFile": "../../../.build/log/tsconfig.tsbuildinfo",
		"module": "esnext",
		"moduleResolution": "bundler",
		"removeComments": false,
		"alwaysStrict": true,
		"experimentalDecorators": true,
		"useDefineForClassFields": false,
		"noImplicitAny": true,
		"noImplicitThis": true,
		"noImplicitReturns": true,
		"pretty": true,
		"rootDir": "src/scripts",
		"paths": {
			"@eliashaeussler/typo3-solver/*": ["./src/scripts/*"]
		},
		"outDir": "../../Public/JavaScript"
	}
}
